{
  "match": {
    "mode": "auto",
    "weights": {
      "name": 0.15,
      "feature": 0.40,
      "tag": 0.45,
      "_comment": "名称定项；特征全文+逐条工艺定工法；标签捕获关键做法冲突"
    },
    "exact": {
      "name_min": 0.98,
      "feature_min": 0.92,
      "tag_min": 0.95
    },
    "fuzzy": {
      "name_min": 0.85,
      "feature_min": 0.78,
      "tag_min": 0.78,
      "total_min": 0.72,
      "reference_min": 0.55
    }
  },
  "pricing": {
    "aggregate": "median",
    "default_management_rate": 0,
    "default_profit_rate": 0,
    "default_tax_rate": 0,
    "cost_net_divisor": 1.1,
    "_cost_net_divisor_comment": "价库合价折净价口径（套/项整价或分量偏少时除以该系数）",
    "reference_line": {
      "name_min": 0.55,
      "feature_min": 0.42,
      "tag_min": 0.45,
      "total_min": 0.58,
      "weak_name_min": 0.78,
      "weak_feature_min": 0.58,
      "_comment": "整项参照：名称+特征+单位须同时达标（匹配引擎单位不一致直接排除）；weak_* 用于弱整项"
    },
    "material_fallback": {
      "enabled": true,
      "min_score": 0.55,
      "_comment": "无整项参照时按品类+规格(如600*600地砖)取历史主材单价中位数"
    }
  },
    "component_judge": {
    "auto_fill_confidence": 0.8,
    "weak_line_confidence": 0.75,
    "review_confidence": 0.55,
    "_comment": "多源融合：≥0.8 自动填；0.75~0.8 弱整项全量导出；0.55~0.75 参考填；<0.55 不填"
  },
  "line_identity": {
    "require_unit": true,
    "require_feature_for_auto_fill": true,
    "min_feature_chars": 8,
    "_comment": "每条清单组价须同时对照名称+项目特征+单位；缺单位拒填，缺/短特征不自动填"
  },
  "import": {
    "pricing_row_requires": ["name", "unit", "quantity"],
    "remark_optional": true
  },
  "export_template": "bidder_export",
  "database_path": "data/cost_pricing.db"
}
